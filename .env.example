COPILOT_CHAT_VERSION=0.45.1
VSCODE_VERSION=1.119.0
GITHUB_API_VERSION=2025-10-01
PORT=4141

# GitHub token (generated by: node run scripts/auth.js)
GITHUB_TOKEN=

# Copilot device IDs (generated by: node run scripts/setup-device.js)
VSCODE_SESSION_ID=
VSCODE_MACHINE_ID=
