COPILOT_CHAT_VERSION=0.45.1
VSCODE_VERSION=1.119.0
GITHUB_API_VERSION=2025-10-01
PORT=4141

# GitHub Enterprise host (omit for github.com), e.g. ghe.example.com
GHE_HOST=

# GitHub token (generated by: node run scripts/auth.js)
GITHUB_TOKEN=

# Copilot device IDs (generated by: node run scripts/setup-device.js)
VSCODE_SESSION_ID=
VSCODE_MACHINE_ID=
EDITOR_DEVICE_ID=

# Set to "true" to completely skip input API key validation
DISABLE_INPUT_AUTH=false

# Route base Opus models to their `-1m` sub-model variants.
# Note: the base models already support a 1M context window — these toggles
# only control whether requests are forwarded to the explicit `-1m` submodel.
ROUTE_OPUS_4_6_TO_1M=false
ROUTE_OPUS_4_7_TO_1M=false
