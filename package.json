{
  "name": "copilot-provider",
  "main": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build index.ts --target=bun --outfile=dist/copilot-provider.js",
    "dev": "bun --watch run index.ts",
    "auth": "bun run scripts/auth.ts",
    "setup-device": "bun run scripts/setup-device.ts",
    "gen-keys": "bun run scripts/gen-keys.ts",
    "fetch-models": "bun run scripts/fetch-models.ts",
    "usage-stats": "bun run scripts/usage-stats.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
